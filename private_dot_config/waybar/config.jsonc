    "pulseaudio",
    "bluetooth",
    "network",
    "power-profiles-daemon",
    "cpu",
    "memory",
    "disk",
    "temperature",
    "backlight",
    // "keyboard-state",
    // "sway/language",
    "battery",
    "tray"
    // "custom/power"
